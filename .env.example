# PostgreSQL
POSTGRES_DB=n8n
POSTGRES_USER=n8n
POSTGRES_PASSWORD=CHANGE_ME

# Zona horaria compartida
GENERIC_TIMEZONE=Europe/Madrid

# Conexion de n8n a la base de datos
DB_TYPE=postgresdb
DB_POSTGRESDB_HOST=n8n-postgres
DB_POSTGRESDB_PORT=5432
DB_POSTGRESDB_DATABASE=n8n
DB_POSTGRESDB_USER=n8n
DB_POSTGRESDB_PASSWORD=CHANGE_ME

# URL publica de n8n
N8N_HOST=n8n.dedaniel.com
N8N_PORT=5678
N8N_PROTOCOL=https
N8N_EDITOR_BASE_URL=https://n8n.dedaniel.com/
WEBHOOK_URL=https://n8n.dedaniel.com/
N8N_PROXY_HOPS=1

# Nombre del certresolver ya configurado en Traefik
TRAEFIK_CERT_RESOLVER=letsencrypt
